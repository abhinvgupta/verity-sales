# Backend API base URL, INCLUDING the /api prefix.
# Leave unset for local dev — the Vite proxy handles /api -> localhost:3000.
# In deployed envs (Vercel), set this to the public backend, e.g.:
#   VITE_API_URL=https://staging.verity.example.com/api
# Vite inlines this at build time, so changes require a redeploy.
VITE_API_URL=
