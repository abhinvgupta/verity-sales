{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "./src",
    // Keep the incremental cache inside outDir so `nest build`'s deleteOutDir
    // resets it each run; otherwise a stale root-level cache makes tsc skip
    // emit after the dir is wiped.
    "tsBuildInfoFile": "./dist/tsconfig.build.tsbuildinfo"
  },
  "exclude": ["node_modules", "test", "dist", "scripts", "**/*spec.ts"]
}
